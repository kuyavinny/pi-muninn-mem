{
  "name": "@kuyavinny/pi-muninn-mem",
  "version": "1.0.6",
  "description": "MuninnDB memory provider for Pi — SSE subscription, context injection, vault bridge",
  "keywords": [
    "pi-package",
    "muninndb",
    "memory",
    "mcp",
    "sse",
    "persistent-memory"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "bin": {
    "muninn-dream": "dist/muninn-dream.mjs"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "build:extension": "npx esbuild index.ts --bundle --format=esm --platform=node --outfile=dist/index.mjs --external:@earendil-works/pi-coding-agent",
    "build:dream": "npx esbuild src/dream.ts --bundle --format=esm --platform=node --outfile=dist/muninn-dream.mjs --banner:js='#!/usr/bin/env node'",
    "build": "npm run build:extension && npm run build:dream",
    "prepublishOnly": "npm run build",
    "check": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {},
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.72.0",
    "pi-mcp-adapter": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "index.ts",
    "dist/",
    "src/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuyavinny/pi-muninn-mem.git"
  },
  "license": "MIT"
}
